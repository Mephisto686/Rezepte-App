{
  "hosting": [
    {
      "target": "main",
      "public": ".",
      "ignore": [
        "firebase.json",
        "firestore.rules",
        "storage.rules",
        "**/.*",
        "**/node_modules/**",
        "FIREBASE_SETUP.md"
      ],
      "headers": [
        {
          "source": "/sw.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        },
        {
          "source": "/manifest.json",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "/index.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "**/*.@(png|jpg|jpeg|gif|svg|ico)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=604800" }
          ]
        }
      ]
    },
    {
      "target": "pretty",
      "public": ".",
      "ignore": [
        "firebase.json",
        "firestore.rules",
        "storage.rules",
        "**/.*",
        "**/node_modules/**",
        "FIREBASE_SETUP.md"
      ],
      "headers": [
        {
          "source": "/sw.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
          ]
        },
        {
          "source": "/manifest.json",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "/index.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "**/*.@(png|jpg|jpeg|gif|svg|ico)",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=604800" }
          ]
        }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
