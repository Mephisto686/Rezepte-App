rules_version = '2';

// ══════════════════════════════════════════════════════════
// Security Rules für die Rezept-App – Gruppen-Modell + Freischaltung
//
// Jeder Nutzer hat eine eigene Rezept-Gruppe und eine eigene
// Einkaufslisten-Gruppe (Standard: privat, nur er selbst).
// Über einen Einladungscode kann man einer bestehenden Gruppe
// beitreten und teilt sich dann die Daten mit deren Mitgliedern.
//
// Neue Registrierungen sind standardmäßig NICHT freigeschaltet (approved:false)
// und haben KI-Funktionen deaktiviert (aiEnabled:false), bis der Admin sie freischaltet.
// Bestandskonten ohne diese Felder gelten als freigeschaltet (Abwärtskompatibilität).
//
// Struktur:
//   /users/{uid}                     → { email, recipeGroupId, shoppingGroupId, approved, aiEnabled }
//   /groups/{groupId}                → { type: 'recipes'|'shopping', members: [uid,...], ownerId }
//   /groups/{groupId}/recipes/{id}
//   /groups/{groupId}/meta/categories
//   /groups/{groupId}/meta/shopping
//   /invites/{code}                  → { groupId, type, createdBy, createdAt }
// ══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == 'bgDIU86EH1T2CLYB7e3TrSN06rr1';
    }
    function isApproved() {
      return isAdmin() || (
        request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('approved', true) == true
      );
    }
    function isMember(data) {
      return request.auth != null && data != null && request.auth.uid in data.members;
    }
    function addingSelfOnly(before, after) {
      return after.members == before.members.concat([request.auth.uid])
             && after.diff(before).affectedKeys().hasOnly(['members']);
    }
    function removingSelfOnly(before, after) {
      return after.members == before.members.removeAll([request.auth.uid])
             && after.diff(before).affectedKeys().hasOnly(['members']);
    }

    // Eigener Nutzer-Datensatz: nur der Nutzer selbst (oder Admin) darf lesen.
    // Neuanlage: approved/aiEnabled müssen false sein (kein Selbst-Freischalten).
    // Update: der Nutzer selbst darf approved/aiEnabled NICHT ändern – nur der Admin.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.approved == false
                    && request.resource.data.aiEnabled == false;
      allow update: if isAdmin()
                    || (request.auth != null && request.auth.uid == userId
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['approved','aiEnabled']));
      allow delete: if isAdmin();
    }

    // Gruppen: lesen/schreiben nur für freigeschaltete Mitglieder.
    // Anlegen bleibt ungated (nötig für den Signup-Flow, bevor der User-Doc mit approved:false existiert;
    // erzeugt nur eine leere, private Gruppe – ohne Freischaltung kommt man nicht an Inhalte/Sync).
    // Admin darf zusätzlich die Gruppen-METADATEN (members/memberEmails) lesen/ändern/löschen,
    // um beim Löschen eines Nutzers dessen Mitgliedschaften aufzuräumen – NICHT aber die eigentlichen
    // Rezepte/Einkaufslisten fremder Gruppen (siehe Unter-Collection-Regel unten, bewusst ohne Admin-Bypass).
    match /groups/{groupId} {
      allow read: if isApproved() && (isAdmin() || isMember(resource.data));
      allow create: if request.auth != null && request.resource.data.members == [request.auth.uid];
      allow update: if isApproved() && (
                      isAdmin()
                      || isMember(resource.data)
                      || addingSelfOnly(resource.data, request.resource.data)
                      || removingSelfOnly(resource.data, request.resource.data)
                    );
      allow delete: if isApproved() && (isAdmin() || isMember(resource.data));

      // Rezepte, Kategorien, Einkaufsliste: nur für freigeschaltete Gruppenmitglieder (bewusst OHNE
      // Admin-Bypass – der Admin verwaltet nur Mitgliedschaften, sieht aber keine fremden Rezeptinhalte)
      match /{document=**} {
        allow read, write: if isApproved() && isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
      }
    }

    // Einladungscodes: jeder freigeschaltete Nutzer darf lesen (zum Einlösen) und eigene erstellen
    match /invites/{code} {
      allow read: if isApproved();
      allow create: if isApproved() && request.resource.data.createdBy == request.auth.uid;
      allow delete: if isApproved();
    }

    // KI-Nutzungsstatistik: jeder eingeloggte Nutzer darf eigene Einträge anlegen (nie ändern/löschen)
    // und NUR seine eigenen Einträge lesen. Der Admin darf alle lesen (Nutzerverwaltungs-Dashboard).
    match /aiUsage/{logId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Registrierungs-Mails: nur exakt an die Admin-Adresse, mit den erwarteten Feldern.
    // Verhindert Missbrauch als offener Mail-Versand. Die "Trigger Email"-Extension liest/verarbeitet
    // dieses Dokument serverseitig (Admin SDK, umgeht Rules) und löscht/aktualisiert es selbst.
    match /mail/{mailId} {
      allow create: if request.auth != null
                    && request.resource.data.to == ['andre.ohlendorf@gmail.com']
                    && request.resource.data.message.subject is string
                    && request.resource.data.message.text is string;
      allow read, update, delete: if false;
    }

    // Alles andere gesperrt
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
