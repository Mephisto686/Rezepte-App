rules_version = '2';

// ══════════════════════════════════════════════════════════
// Security Rules für die Rezept-App – Gruppen-Modell
//
// Jeder Nutzer hat eine eigene Rezept-Gruppe und eine eigene
// Einkaufslisten-Gruppe (Standard: privat, nur er selbst).
// Über einen Einladungscode kann man einer bestehenden Gruppe
// beitreten und teilt sich dann die Daten mit deren Mitgliedern.
//
// Struktur:
//   /users/{uid}                     → { email, recipeGroupId, shoppingGroupId }
//   /groups/{groupId}                → { type: 'recipes'|'shopping', members: [uid,...], ownerId }
//   /groups/{groupId}/recipes/{id}
//   /groups/{groupId}/meta/categories
//   /groups/{groupId}/meta/shopping
//   /invites/{code}                  → { groupId, type, createdBy, createdAt }
// ══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(data) {
      return request.auth != null && data != null && request.auth.uid in data.members;
    }
    function addingSelfOnly(before, after) {
      return after.members == before.members.concat([request.auth.uid])
             && after.diff(before).affectedKeys().hasOnly(['members']);
    }
    function removingSelfOnly(before, after) {
      return after.members == before.members.removeAll([request.auth.uid])
             && after.diff(before).affectedKeys().hasOnly(['members']);
    }

    // Eigener Nutzer-Datensatz: nur der Nutzer selbst
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Gruppen: lesen/schreiben nur für Mitglieder; beitreten/verlassen nur die eigene Mitgliedschaft
    match /groups/{groupId} {
      allow read: if isMember(resource.data);
      allow create: if request.auth != null && request.resource.data.members == [request.auth.uid];
      allow update: if isMember(resource.data)
                    || addingSelfOnly(resource.data, request.resource.data)
                    || removingSelfOnly(resource.data, request.resource.data);
      allow delete: if isMember(resource.data);

      // Rezepte, Kategorien, Einkaufsliste: nur für Gruppenmitglieder
      match /{document=**} {
        allow read, write: if isMember(get(/databases/$(database)/documents/groups/$(groupId)).data);
      }
    }

    // Einladungscodes: jeder eingeloggte Nutzer darf lesen (zum Einlösen) und eigene erstellen
    match /invites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow delete: if request.auth != null;
    }

    // KI-Nutzungsstatistik: jeder eingeloggte Nutzer darf eigene Einträge anlegen (nie ändern/löschen)
    // und alle Einträge lesen (für die Statistik-Ansicht in den Einstellungen – bewusst offen,
    // da aktuell nur wenige, einander bekannte Nutzer die App teilen).
    match /aiUsage/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Alles andere gesperrt
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
